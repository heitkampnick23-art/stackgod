# xcodegen template — vars: {{APP_NAME}}, {{BUNDLE_ID}}, {{TEAM_ID}}
name: {{APP_NAME}}
options:
  bundleIdPrefix: {{BUNDLE_ID_PREFIX}}
  deploymentTarget:
    iOS: "17.0"
  developmentLanguage: en
settings:
  base:
    DEVELOPMENT_TEAM: {{TEAM_ID}}
    SWIFT_VERSION: "5.10"
    TARGETED_DEVICE_FAMILY: "1"   # iPhone only per feedback_iphone_only_ios17
    SUPPORTS_MACCATALYST: NO
    SUPPORTS_XR_DESIGNED_FOR_IPHONE_IPAD: NO
targets:
  {{APP_NAME}}:
    type: application
    platform: iOS
    sources: [Sources]
    info:
      path: Sources/Info.plist
      properties:
        CFBundleDisplayName: {{APP_NAME}}
        UILaunchScreen: {}
    entitlements:
      path: Sources/{{APP_NAME}}.entitlements
      properties:
        com.apple.developer.applesignin: [Default]
        com.apple.developer.in-app-payments: [{{MERCHANT_ID}}]
    settings:
      base:
        PRODUCT_BUNDLE_IDENTIFIER: {{BUNDLE_ID}}
        MARKETING_VERSION: "1.0.0"
        CURRENT_PROJECT_VERSION: "1"
